{"name": "ai_neno", "version": "1.0.0", "description": "A hybrid AI chat application combining ChatGPT and Claude features with Ollama", "main": "server/index.ts", "scripts": {"dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"", "dev:server": "cd server && npm run dev", "dev:client": "cd client && npm run dev", "build": "npm run build:server && npm run build:client", "build:server": "cd server && npm run build", "build:client": "cd client && npm run build", "start": "node server/dist/index.js", "test": "jest"}, "keywords": ["ai", "chat", "ollama", "gpt", "claude"], "author": "yatindrak40-max", "license": "MIT", "devDependencies": {"concurrently": "^8.2.0", "typescript": "^5.3.0"}, "workspaces": ["server", "client"]}